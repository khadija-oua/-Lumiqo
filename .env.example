# --- MySQL (used by the `mysql` service + injected into `backend`) ---
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_DATABASE=lumiqo
MYSQL_USER=lumiqo_user
MYSQL_PASSWORD=changeme_user

# --- Auth ---
# Generate with: openssl rand -base64 64
JWT_SECRET=replace_with_a_long_random_string

# --- CORS (backend) ---
# For local dev with the Vite frontend, the default in server.js
# (http://localhost:5173) is fine — you can leave this empty.
CORS_ORIGIN=

# --- Gemini (AI) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# --- Google Drive (OAuth 2.0 with refresh token) ---
# Generate the refresh token once via:  cd backend && npm run drive:token
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=

# --- Host-side port overrides (optional) ---
BACKEND_PORT=5000
FRONTEND_PORT=5173