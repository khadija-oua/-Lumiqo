# Copy this file to `.env` and fill in real values. The real `.env` is gitignored.

# --- MySQL ---
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_DATABASE=smartmoodle
MYSQL_USER=smartmoodle
MYSQL_PASSWORD=changeme_user

# --- Auth ---
JWT_SECRET=replace_with_a_long_random_string

# --- Gemini (AI) ---
GEMINI_API_KEY=

# --- Google Drive (OAuth 2.0 with refresh token) ---
# Required for the PDF material endpoints. See "Google Drive setup" in README.
# Generate a refresh token via:  cd backend && node scripts/get-refresh-token.js
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Folder ID from your personal Drive (the part after /folders/ in the URL).
GOOGLE_DRIVE_FOLDER_ID=

# Legacy — unused since the OAuth refactor. Left for posterity; safe to delete.
# GOOGLE_DRIVE_CREDENTIALS_PATH=/app/credentials/service-account.json

# --- Ports (host-side) ---
BACKEND_PORT=5000
FRONTEND_PORT=5173
