
# --- Server ---
# Railway injects PORT automatically — leave it commented out in production.
# PORT=5000
NODE_ENV=production

# --- Database (MySQL) ---
# In Railway, set these to the values shown in the MySQL service's "Connect" tab.
# Use the PRIVATE host (`mysql.railway.internal`) when backend and DB are in the
# same Railway project — internal traffic stays within Railway's network.
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# Set to "true" when DB traffic goes over the public internet (Railway public
# proxy, external MySQL host, etc.). Leave empty/false for private networking.
DB_SSL=false

# --- Auth ---
# Generate with: openssl rand -base64 64
# MUST be different between dev and prod. Rotating this invalidates all JWTs.
JWT_SECRET=

# --- CORS ---
# Comma-free single origin in production: your Vercel deployment URL.
# Example: https://lumiqo.vercel.app
# Falls back to http://localhost:5173 if unset (handled in server.js).
CORS_ORIGIN=

# --- Gemini (Google AI) ---
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# --- Google Drive (OAuth 2.0) ---
# See README "Google Drive setup". The refresh token is generated ONCE locally
# via `npm run drive:token` and pasted here. Never regenerate from production.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=